# GPU Worker Environment Configuration

# Redis (required for job queue)
REDIS_URL=redis://localhost:6379/0

# Supabase (for file storage and uploads)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key
DEFAULT_BUCKET=generated

# Model storage (use persistent disk path)
MODELS_DIR=/mnt/models
OUTPUT_DIR=./outputs

# GPU device
DEVICE=cuda:0

# Models (change to upgrade)
IMAGE_MODEL_ID=black-forest-labs/FLUX.2-klein-9B
VIDEO_MODEL_ID=Lightricks/LTX-2

# Server
HOST=0.0.0.0
PORT=8000

# Worker identity (for multi-GPU setups, give each a unique name)
# WORKER_ID=gpu-worker-1
